# ----- REQUIRED -----
# JWT signing key. There is NO default — the app refuses to boot without this.
# Generate a strong one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Use DIFFERENT keys per environment. Never commit this value.
SECRET_KEY=

# ----- Database -----
DATABASE_URL=sqlite:///./affiliate_images.db

# ----- API Keys -----
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
FAL_API_KEY=your_fal_api_key_here
GOOGLE_API_KEY=your_google_cloud_api_key_here
IDEOGRAM_API_KEY=
DEEPGRAM_API_KEY=
REPLICATE_API_TOKEN=

# ----- Image Generation -----
IMAGE_PROVIDER=gemini  # Options: gemini, fal, openai

# ----- Auth / JWT -----
# JWT_EXPIRY_MINUTES defaults to 1440 (24h). Lower = better security, more re-logins.
JWT_EXPIRY_MINUTES=1440

# ----- API Configuration -----
DEBUG=False
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
# Set to false in production. When true, allow_origins becomes ["*"] which is
# unsafe with allow_credentials=True (Starlette reflects Origin -> any origin
# becomes trusted). Always keep false in prod.
CORS_ALLOW_ALL=true

# ----- Defaults -----
DEFAULT_VERTICAL=home_insurance
IMAGES_PER_GENERATION=5
